{
  "name": "sf-paleo-coastlines",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "capture:maps": "node scripts/capture_map_views.mjs",
    "paleo-coastlines:generate": "python3 scripts/generate_paleo_coastlines.py",
    "paleo-coastlines:terrain-tiles": "python3 scripts/generate_terrain_tiles.py",
    "paleo-coastlines:inventory": "python3 scripts/build_survey_inventory.py --with-gdalinfo",
    "paleo-coastlines:nw-gap-sources": "python3 scripts/discover_nw_gap_sources.py",
    "paleo-coastlines:usgs-2023-sf-dem": "python3 scripts/acquire_usgs_2023_sf_lidar_dem.py",
    "paleo-coastlines:usgs-coned-sf": "python3 scripts/acquire_usgs_coned_sf_2m.py",
    "paleo-coastlines:usgs-bay-dem": "python3 scripts/acquire_usgs_sf_bay_1m_dem.py",
    "paleo-coastlines:bay-source-footprints": "python3 scripts/acquire_usgs_sf_bay_source_footprints.py",
    "paleo-coastlines:rivers": "python3 scripts/generate_paleo_rivers.py",
    "paleo-coastlines:stats": "python3 scripts/generate_sealevel_stats.py",
    "paleo-coastlines:detail-diagnosis": "python3 scripts/diagnose_terrain_detail_points.py",
    "paleo-coastlines:display-audit": "python3 scripts/audit_terrain_display_resolution.py"
  },
  "dependencies": {
    "@deck.gl/geo-layers": "^9.2.11",
    "@deck.gl/react": "^9.2.11",
    "deck.gl": "^9.2.11",
    "lucide-react": "^0.577.0",
    "maplibre-gl": "^5.19.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-map-gl": "^8.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.8"
  }
}
